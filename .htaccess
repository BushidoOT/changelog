Options -Indexes
DirectoryIndex index.php

<IfModule mod_rewrite.c>
RewriteEngine On
RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP_HOST} ^www\. [NC]
RewriteRule ^ https://viohy.com%{REQUEST_URI} [L,R=301]

RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Tek parçalı kullanıcı profillerini yeni premium tema motoruna gönder.
RewriteRule ^(?!login/?$|register/?$|logout/?$|dashboard(?:/|$)|admin/?$|go(?:/|$)|health/?$|install(?:/|$))([A-Za-z0-9._-]{3,30})/?$ profile.php?u=$1 [QSA,L,NC]

# Panel, giriş, kayıt, analiz ve diğer uygulama yolları ana yönlendiricide kalır.
RewriteRule ^ index.php [QSA,L]
</IfModule>

<IfModule mod_headers.c>
Header always set X-Content-Type-Options "nosniff"
Header always set X-Frame-Options "SAMEORIGIN"
Header always set Referrer-Policy "strict-origin-when-cross-origin"
Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(self)"
</IfModule>

<FilesMatch "^(config\.php|app\.php|templates\.php)$">
Require all denied
</FilesMatch>
